# Database
DATABASE_URL=postgresql://condominio_user:condominio_password@localhost:5432/condominio_db
DB_HOST=postgres
DB_PORT=5432
DB_NAME=condominio_db
DB_USER=condominio_user
DB_PASSWORD=condominio_password

# Backend Server
BACKEND_PORT=3001
NODE_ENV=development

# Frontend
VITE_API_BASE_URL=http://localhost:3001/api

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRATION=7d

# Admin Setup (for initial seeding)
ADMIN_EMAIL=admin@condominio.local
ADMIN_PASSWORD=admin123

# Optional: Third-party services (for future phases)
# STRIPE_SECRET_KEY=
# SENDGRID_API_KEY=
# TWILIO_ACCOUNT_SID=
