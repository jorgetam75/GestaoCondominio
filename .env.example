# Database (use DATABASE_URL in production, or set strong DB_* vars)
DATABASE_URL=postgresql://condominio_user:condominio_password@localhost:5432/condominio_db
DB_HOST=postgres
DB_PORT=5432
DB_NAME=condominio_db
DB_USER=condominio_user
DB_PASSWORD=condominio_password

# Backend Server
BACKEND_PORT=3001
NODE_ENV=development

# Behind nginx/Render/Fly: set so rate limits and IPs are correct
# TRUST_PROXY=true

# Frontend (build-time; use your public API URL in production)
VITE_API_BASE_URL=http://localhost:3001/api

# JWT — production: min 32 chars, random, never commit real value
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRATION=7d

# Admin Setup (for initial seeding only)
ADMIN_EMAIL=admin@condominio.local
ADMIN_PASSWORD=admin123

# CORS — production: required; comma-separated for multiple SPA origins
# Example: https://app.example.com,https://admin.example.com
CORS_ORIGIN=http://localhost:5173

# Optional: Third-party services (for future phases)
# STRIPE_SECRET_KEY=
# SENDGRID_API_KEY=
# TWILIO_ACCOUNT_SID=

#
# Production checklist (NODE_ENV=production):
# - JWT_SECRET: strong, 32+ characters, unique per environment
# - CORS_ORIGIN: exact browser origin(s), not "*"
# - DATABASE_URL or non-default DB_PASSWORD
# - ADMIN_PASSWORD: not admin123
# - TRUST_PROXY=true when behind a reverse proxy
#
